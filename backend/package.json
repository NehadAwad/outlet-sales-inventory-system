{
  "name": "pos-backend",
  "private": true,
  "version": "0.1.0",
  "description": "POS API — Express, TypeScript, TypeORM, PostgreSQL",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typeorm": "typeorm-ts-node-commonjs",
    "migration:generate": "npm run typeorm -- migration:generate src/db/migrations/Migration -d src/db/data-source.ts",
    "migration:create": "npm run typeorm -- migration:create src/db/migrations/Migration",
    "migration:run": "typeorm migration:run -d dist/db/data-source.js",
    "migration:run:dev": "npm run typeorm -- migration:run -d src/db/data-source.ts",
    "migration:revert:dev": "npm run typeorm -- migration:revert -d src/db/data-source.ts",
    "seed": "tsx src/db/seed.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "pg": "^8.20.0",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.29",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}

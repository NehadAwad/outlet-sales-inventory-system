# Copy to `.env` for local dev (never commit real secrets).
# Browser calls this URL; use host machine + backend port.
VITE_API_BASE_URL=http://localhost:5000/api/v1

# Vercel: Project → Settings → Environment Variables → add VITE_API_BASE_URL
# for Production (and Preview if needed). Use your deployed API origin including
# path /api/v1, e.g. https://your-api.onrender.com/api/v1
#
# Ensure the API server CORS_ORIGIN includes your Vercel URL(s), e.g.
# https://your-app.vercel.app
